# Site URL (used for sitemap, canonical URLs, OpenGraph)
SITE_URL=https://airindex.today

# AQI data cache TTL in minutes
CACHE_TTL_MINUTES=30

# Maximum number of cached locations
CACHE_MAX_ENTRIES=10000

# Open-Meteo commercial API key (uses customer-*.open-meteo.com when set)
# OPENMETEO_API_KEY=

# Geo services (shared with uv-site / pollennow)
# GEO_SERVICE_URL=http://geo-service:3850
# IP_GEO_URL=http://ip-geo:3849

# Feedback file path
# FEEDBACK_FILE=/app/data/feedback.jsonl

# AdSense
# NEXT_PUBLIC_ADSENSE_ID=
