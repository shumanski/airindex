# =============================================================================
# airindex — Environment Configuration
# =============================================================================
# Copy this file to .env and uncomment/edit what you need.
# The app picks ONE Open-Meteo mode based on what's set (checked top-down):
#
#   1. OPENMETEO_HOST set        → SELF-HOSTED (all AQI + weather via your instance)
#   2. OPENMETEO_API_KEY set     → PAID API    (customer-*.open-meteo.com, no rate limit)
#   3. neither set               → FREE API    (api.open-meteo.com, rate-limited)
#
# On startup the app logs which mode it chose, e.g.:
#   [aqi-api] mode=self-hosted AQI=http://open-meteo:8080/v1/air-quality ...
# =============================================================================


# --------------- Site --------------------------------------------------------

# Canonical URL (used in sitemap.xml, robots.txt, OpenGraph tags)
SITE_URL=https://airindex.today

# In-memory cache for AQI data responses
CACHE_TTL_MINUTES=30
CACHE_MAX_ENTRIES=10000


# --------------- Open-Meteo mode (pick ONE section, comment out the rest) ----

# --- Option A: Self-hosted Open-Meteo (recommended for production) ----------
# Run your own Open-Meteo instance (see uv-site/open-meteo/docker-compose.yml).
# When set, weather/AQI requests go to this host instead of the public API.
# OPENMETEO_HOST=http://open-meteo:8080

# --- Option B: Paid Open-Meteo API key --------------------------------------
# Get a key at https://open-meteo.com/en/pricing (from €15/mo).
# When OPENMETEO_HOST is NOT set, this key is used for weather/AQI requests.
# Also used as geocoding fallback (for cities not in geo-service DB).
# OPENMETEO_API_KEY=your-api-key-here

# --- Option C: Free public API (default) ------------------------------------
# Leave both OPENMETEO_HOST and OPENMETEO_API_KEY commented out.
# Uses api.open-meteo.com (rate-limited, non-commercial).


# --------------- Internal services -------------------------------------------

# geo-service: city search and lookup (Docker internal, on caddy_net)
# Not needed — code defaults to http://geo-service:3850
# Uncomment only if you changed the container name or port.
# GEO_SERVICE_URL=http://geo-service:3850

# ip-geo: IP-to-location for auto-redirect (Docker internal, on caddy_net)
# Not needed — code defaults to http://ip-geo:3849
# Uncomment only if you changed the container name or port.
# IP_GEO_URL=http://ip-geo:3849


# --------------- Feedback (optional) -----------------------------------------

# Path to feedback JSONL file inside the container
# FEEDBACK_FILE=/app/data/feedback.jsonl


# --------------- AdSense (optional) ------------------------------------------

# Google AdSense — set after creating ad units in the dashboard.
# These are build-time vars (NEXT_PUBLIC_), so rebuild after changing.
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX


# =============================================================================
# Quick-start examples
# =============================================================================
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ FREE (just trying it out locally)                                      │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ SITE_URL=http://localhost:3000                                         │
# │ CACHE_TTL_MINUTES=5                                                    │
# │ CACHE_MAX_ENTRIES=100                                                  │
# │ # (leave OPENMETEO_HOST and OPENMETEO_API_KEY commented out)           │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ SELF-HOSTED (production, recommended — saves ~€40/mo in API costs)    │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ SITE_URL=https://airindex.today                                        │
# │ CACHE_TTL_MINUTES=30                                                   │
# │ CACHE_MAX_ENTRIES=10000                                                │
# │ OPENMETEO_HOST=http://open-meteo:8080                                 │
# │ GEO_SERVICE_URL=http://geo-service:3850                               │
# │ IP_GEO_URL=http://ip-geo:3849                                         │
# └─────────────────────────────────────────────────────────────────────────┘
